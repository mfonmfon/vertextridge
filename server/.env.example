# Server 
NODE_ENV=development

# Supabase 
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth 
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

#  Security
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

#CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

#Rate Limiting 
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Crypto Deposit Wallets 
# Format: address::NetworkLabel (comma-separated)
# Example: bc1qADDRESS::Bitcoin (BTC),0xADDRESS::Ethereum (ERC-20)
CRYPTO_WALLETS=

#Bank Transfer Details 
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_ROUTING_NUMBER=
BANK_SWIFT_CODE=
BANK_IBAN=
BANK_NAME=
BANK_BRANCH=
BANK_REFERENCE_PREFIX=DEP

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=TradZ
SMTP_FROM_EMAIL=noreply@tradz.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Anthropic API
ANTHROPIC_API_KEY=
